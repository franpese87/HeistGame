--!strict
-- StealthSystem.luau
-- Shared logic for calculating a player's detection level.
--
-- Detection works on a 0-100 scale:
--   0-30  → Undetected (green)
--   31-70 → Suspicious (yellow) — guards walk toward player
--   71-99 → Almost caught (orange)
--   100   → Caught → alarm triggered
--
-- Factors that affect detection:
--   • Distance to the nearest guard/camera
--   • Whether the player is in a light or shadow zone
--   • Player movement speed (running raises noise)
--   • Whether the player is crouching
--   • Whether the player is wearing a disguise

local StealthSystem = {}

export type DetectionTier = "Undetected" | "Suspicious" | "Spotted" | "Caught"

export type PlayerStealthState = {
	detection: number,   -- 0-100
	noiseLevel: number,  -- 0-100 (contributes to nearby guard awareness)
	isCrouching: boolean,
	isDisguised: boolean,
	inShadow: boolean,
}

-- Thresholds
local SUSPICIOUS_THRESHOLD = 31
local SPOTTED_THRESHOLD    = 71
local CAUGHT_THRESHOLD     = 100

-- How fast detection rises/falls per server tick (in detection units)
local DETECTION_RISE_RATE = 8   -- per second when visible
local DETECTION_FALL_RATE = 4   -- per second when hidden
local NOISE_DECAY_RATE    = 12  -- per second

--- Returns the DetectionTier for a given detection value.
function StealthSystem.getTier(detection: number): DetectionTier
	if detection >= CAUGHT_THRESHOLD then
		return "Caught"
	elseif detection >= SPOTTED_THRESHOLD then
		return "Spotted"
	elseif detection >= SUSPICIOUS_THRESHOLD then
		return "Suspicious"
	else
		return "Undetected"
	end
end

--- Calculates the noise generated by a moving character.
--- speed: studs/second; crouching halves noise.
function StealthSystem.calculateNoise(speed: number, isCrouching: boolean): number
	local base = math.clamp(speed / 20, 0, 1) * 100
	if isCrouching then base = base * 0.4 end
	return base
end

--- Returns the visibility multiplier for a character (0 = fully hidden, 1 = fully visible).
--- Factors: light level (0-1), crouching, disguise.
function StealthSystem.visibilityMultiplier(state: PlayerStealthState): number
	local multiplier = 1.0
	if state.inShadow    then multiplier = multiplier * 0.3 end
	if state.isCrouching then multiplier = multiplier * 0.5 end
	if state.isDisguised then multiplier = multiplier * 0.4 end
	return multiplier
end

--- Advances detection for one tick.
--- distanceToThreat: studs to nearest guard/camera (-1 = no threat in range)
--- dt: delta time in seconds
function StealthSystem.tick(
	state: PlayerStealthState,
	distanceToThreat: number,
	dt: number
): PlayerStealthState
	local newState = table.clone(state)

	-- Noise decays over time
	newState.noiseLevel = math.max(0, state.noiseLevel - NOISE_DECAY_RATE * dt)

	local threatened = distanceToThreat >= 0 and distanceToThreat < 50
	if threatened then
		-- Detection rises faster when closer
		local proximityFactor = 1 - math.clamp(distanceToThreat / 50, 0, 1)
		local visibility = StealthSystem.visibilityMultiplier(state)
		local noiseFactor = state.noiseLevel / 100
		local combined = math.max(visibility, noiseFactor * 0.6)
		newState.detection = math.clamp(
			state.detection + DETECTION_RISE_RATE * combined * (1 + proximityFactor) * dt,
			0, 100
		)
	else
		-- Detection slowly falls when no threat is nearby
		newState.detection = math.clamp(
			state.detection - DETECTION_FALL_RATE * dt,
			0, 100
		)
	end

	return newState
end

--- Creates a default (fresh) stealth state for a player.
function StealthSystem.defaultState(): PlayerStealthState
	return {
		detection   = 0,
		noiseLevel  = 0,
		isCrouching = false,
		isDisguised = false,
		inShadow    = false,
	}
end

return StealthSystem
